<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <!-- Заголовок -->

    <!-- Текущий баланс -->

    <!-- Введенное число -->
    <TextView
        android:id="@+id/InputNumber"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:textColor="@color/txt_color"
        android:textSize="28sp"
        android:gravity="center"
        android:background="@android:drawable/editbox_background"
        android:layout_marginBottom="16dp"
        android:padding="8dp" />

    <!-- Кнопки цифр -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginBottom="16dp">

        <ImageView
            android:id="@+id/btn1"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_1"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn2"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_2"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn3"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_3"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn4"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_4"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn5"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_5"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn6"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_6"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn7"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_7"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn8"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_8"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn9"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_9"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btn0"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:src="@drawable/counter_0"
            android:layout_columnWeight="1"
            android:textSize="20sp"
            android:layout_margin="4dp" />

        <ImageView
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_columnWeight="1"
            android:src="@drawable/backspace"
            android:layout_margin="4dp" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_columnWeight="1" />

    </GridLayout>

    <!-- Кнопки + и - -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/btnAdd"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="+"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnSubtract"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="-"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:backgroundTint="@android:color/holo_red_dark" />

    </LinearLayout>

</LinearLayout>