<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/price_color">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="45dp"
        android:background="@color/price_color"
        android:contentDescription="Назад"
        android:scaleType="centerInside"
        android:src="@drawable/back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tasksRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        app:layout_constraintBottom_toTopOf="@id/addButtonPrice"
        app:layout_constraintTop_toBottomOf="@id/btnBack"
        tools:layout_editor_absoluteX="6dp" />

    <ImageView
        android:id="@+id/addButtonPrice"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="30dp"
        android:layout_marginStart="12dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Добавить"
        android:src="@drawable/plus"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:id="@+id/balanceButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_margin="30dp"
        android:src="@drawable/saving"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/balanceText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textSize="25dp"
        app:layout_constraintRight_toLeftOf="@id/balanceButton"
        app:layout_constraintBottom_toBottomOf="@id/balanceButton"
        tools:layout_editor_absoluteX="235dp"
        tools:layout_editor_absoluteY="677dp" />

</androidx.constraintlayout.widget.ConstraintLayout>