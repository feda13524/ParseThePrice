<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ParseThePrice" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Делаем верхнюю полоску (статус бар) прозрачной -->
        <item name="android:statusBarColor">@android:color/transparent</item>

        <!-- Делаем нижнюю полоску (навигация) прозрачной -->
        <item name="android:navigationBarColor">@android:color/transparent</item>

        <!-- Разрешаем рисовать поверх полосок -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
</resources>
